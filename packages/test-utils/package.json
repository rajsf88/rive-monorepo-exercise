{
    "name": "@rive-monorepo/test-utils",
    "version": "0.1.0",
    "description": "Shared test utilities, mocks, and fixtures for the Rive monorepo",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "lint": "eslint src",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@rive-monorepo/core": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.4.0",
        "typescript": "^5.7.3"
    }
}