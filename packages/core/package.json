{
    "name": "@rive-monorepo/core",
    "version": "0.1.0",
    "description": "Shared types, constants, and version info for the Rive monorepo",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "test": "vitest run",
        "lint": "eslint src tests",
        "format": "prettier --write src tests",
        "clean": "rm -rf dist"
    },
    "devDependencies": {
        "tsup": "^8.4.0",
        "vitest": "^3.0.6",
        "typescript": "^5.7.3"
    }
}