{
  "name": "rive-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Rive-inspired monorepo: web editor, desktop editor, runtimes, shared packages, CI/CD infrastructure",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev --parallel",
    "release": "python3 scripts/release.py",
    "build:all": "bash scripts/build-all.sh",
    "check-affected": "bash scripts/check-affected.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "eslint": "^9.20.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "prettier": "^3.4.2",
    "vitest": "^3.0.6"
  },
  "packageManager": "pnpm@9.15.5"
}
