{
    "name": "@rive-monorepo/desktop-editor",
    "version": "0.1.0",
    "private": true,
    "description": "Rive desktop editor — Electron wrapper (macOS + Windows)",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "electron .",
        "build": "tsc -p tsconfig.electron.json && node -e \"if (process.platform !== 'linux') require('child_process').execSync('electron-builder --config electron-builder.config.js --publish never', { stdio: 'inherit' })\"",
        "build:mac": "tsc -p tsconfig.electron.json && electron-builder --config electron-builder.config.js --mac --publish never",
        "build:win": "tsc -p tsconfig.electron.json && electron-builder --config electron-builder.config.js --win --publish never",
        "lint": "eslint src",
        "clean": "rm -rf dist-electron release"
    },
    "dependencies": {
        "@rive-monorepo/core": "workspace:*",
        "electron-updater": "^6.3.9"
    },
    "devDependencies": {
        "electron": "^34.1.1",
        "electron-builder": "^25.1.8",
        "@electron/notarize": "^2.5.0",
        "typescript": "^5.7.3",
        "eslint": "^9.20.0",
        "@typescript-eslint/eslint-plugin": "^8.24.1",
        "@typescript-eslint/parser": "^8.24.1"
    }
}
